class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        // For each index go left and right until we find a smaller element
        // That would be the width
        // Height would be current element
        int n = heights.size();
        int maxArea = -1;
        for(int i=0;i<n;i++){
            // Searching left
            int left = i;
            int widthLeft = 0;
            while(left--){
                if(heights[left] < heights[i]){
                    break;
                }
                widthLeft++;
            }
            int right = i;
            int widthRight = 0;
            // Searching right
            while(right < n){
                if(heights[right] < heights[i]){
                    break;
                }
                widthRight++;
                right++;
            }
            // cout<<"Width for "<<heights[i]<<"->"<<widthRight+widthLeft;
            // cout<<endl;
            int width = widthRight+widthLeft;
            int area = heights[i] * width;
            maxArea = max(area,maxArea);
        }
        return maxArea;
    }
};
