class StockSpanner {
public:
    // Monotonic decreasing stack
    // Each element stores: {price, span}
    // span = number of consecutive days this price dominates
    stack<pair<int,int>> st;

    StockSpanner() {
    }

    int next(int price) {

        // Minimum span is 1 (the current day itself)
        int span = 1;

        // If current price is greater than or equal to previous prices,
        // those previous prices cannot limit the span anymore
        while (!st.empty() && price >= st.top().first) {

            // Instead of counting day-by-day,
            // reuse the span already computed for that price
            span += st.top().second;

            // Remove smaller prices since they are no longer useful
            st.pop();
        }

        // Push current price with its computed span
        st.push({price, span});

        return span;
    }
};
