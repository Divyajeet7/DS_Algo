/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    bool isSameTree(TreeNode* p, TreeNode* q) {
        if(p == NULL && q == NULL)return true;
        if(p == NULL || q == NULL)return false; // Signifies one is NULL and other isn't as we already checked that both are not NULL
        if(p->val != q->val)return false; // Checking whether root node of both trees are equal
        return isSameTree(p->left,q->left) && isSameTree(p->right,q->right); // Checking whether left subtree and right subtree of both trees are equal
    }
};
