/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    int findHeight(TreeNode* root){
        if(root == NULL)return 0;

        int lh = findHeight(root->left); // Finding left height
        int rh = findHeight(root->right); // Finding right height

        if(lh == -1 || rh == -1)return -1; // If left or right height is not balanced the tree is ultimately not balanced hence we return -1
        if(abs(rh - lh) > 1)return -1; // If diff of left and right height is greater than 1 the tree is not balanced hence we return -1

        return 1 + max(lh,rh); // Implies tree is balanced and we simply return the height of the tree
    }
    bool isBalanced(TreeNode* root) {
        // For a tree to be balanced it's left and right height diff should not exceed 1
        int height = findHeight(root);
        return height == -1 ? false : true; // If height comes as -1 it implies tree is not balanced, if actual height is returned implies tree is balanced
    }
};
